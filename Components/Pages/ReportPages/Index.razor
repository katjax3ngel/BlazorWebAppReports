@page "/reports"
@using Microsoft.AspNetCore.Components.QuickGrid
@using Microsoft.EntityFrameworkCore
@using BlazorWebAppReports.Models
@using BlazorWebAppReports.Data
@implements IAsyncDisposable
@inject IDbContextFactory<BlazorWebAppReports.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Index</PageTitle>

<h1>Index</h1>

<p>
    <a href="reports/create">Create New</a>
</p>

<QuickGrid Class="table" Items="context.Report">
    <PropertyColumn Property="report =>report.Id" />
    <PropertyColumn Property="report => report.Title" />
    <PropertyColumn Property="report => report.DueDate" />
    <PropertyColumn Property="report => report.Type" />
    <PropertyColumn Property="report => report.Priority" />

    <TemplateColumn Context="report">
        <a href="@($"reports/edit?id={report.Id}")">Edit</a> |
        <a href="@($"reports/details?id={report.Id}")">Details</a> |
        <a href="@($"reports/delete?id={report.Id}")">Delete</a>
    </TemplateColumn>
</QuickGrid>

@code {
    private ApplicationDbContext context = default!;

    protected override void OnInitialized()
    {
        context = DbFactory.CreateDbContext();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
