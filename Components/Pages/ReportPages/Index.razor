@page "/reports"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.QuickGrid
@using Microsoft.EntityFrameworkCore
@using BlazorWebAppReports.Models
@using BlazorWebAppReports.Data
@using System.Text
@inject IJSRuntime JS
@inject IDbContextFactory<BlazorWebAppReports.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Index</PageTitle>

<h1>Tickets</h1>

<input class="form-control" placeholder="Search tickets..." @bind="searchText" @bind:event="oninput" />

<br />

<p>
    <a href="reports/create">Create New</a>
</p>

<a href="/archived-reports">
    <button type="button">Access Archived</button>
</a>

<a href="/deleted-reports">
    <button type="button">Access Deleted</button>
</a>

<br />
<br />

<button type="button" @onclick="ExportCsv">Export CSV</button>

<br />
<br />

<QuickGrid Class="table" Items="FilteredReports.AsQueryable()" Pagination="pagination">
    <PropertyColumn Property="report => report.Id" Sortable="true" />
    <PropertyColumn Property="report => report.Title" Sortable="true" />
    <PropertyColumn Property="report => report.DueDate" Sortable="true" />
    <PropertyColumn Property="report => report.Type" Sortable="true" />
    <PropertyColumn Property="report => report.Priority" Sortable="true" />
    <PropertyColumn Property="report => report.AssignedTo" Title="Assigned To" Sortable="true" />
    <PropertyColumn Property="report => report.Status" Sortable="true" />
    <PropertyColumn Property="report => report.Description" Sortable="true" />

    <TemplateColumn Context="report">
        <a href="@($"reports/edit?id={report.Id}")">
            <button type="button">Edit</button>
        </a>

        <a href="@($"reports/details?id={report.Id}")">
            <button type="button">Details</button>
        </a>

        <button type="button" @onclick="() => ArchiveReport(report.Id)">Archive</button>
        <button type="button" @onclick="() => DeleteReport(report.Id)">Delete</button>
    </TemplateColumn>
</QuickGrid>

<Paginator State="pagination" />

@code {
    private PaginationState pagination = new PaginationState { ItemsPerPage = 10 };
    private List<Report> reports = new();
    private string searchText = "";

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        reports = await context.Report.ToListAsync();
    }

    private async Task ArchiveReport(int id)
    {
        using var context = DbFactory.CreateDbContext();

        var report = await context.Report.FindAsync(id);

        if (report is not null)
        {
            var archivedReport = new ArchivedReport
            {
                OriginalReportId = report.Id,
                Title = report.Title,
                DueDate = report.DueDate.ToDateTime(TimeOnly.MinValue),
                Type = report.Type,
                Priority = report.Priority,
                Description = report.Description,
                ArchivedDate = DateTime.Now,
                AssignedTo = report.AssignedTo,
                Status = report.Status
            };

            context.ArchivedReports.Add(archivedReport);
            context.Report.Remove(report);

            await context.SaveChangesAsync();
        }

        NavigationManager.NavigateTo("/reports", forceLoad: true);
    }

    private async Task DeleteReport(int id)
    {
        using var context = DbFactory.CreateDbContext();

        var report = await context.Report.FindAsync(id);

        if (report is not null)
        {
            var deletedReport = new DeletedReport
            {
                OriginalReportId = report.Id,
                Title = report.Title,
                DueDate = report.DueDate.ToDateTime(TimeOnly.MinValue),
                Type = report.Type,
                Priority = report.Priority,
                Description = report.Description,
                DeletedDate = DateTime.Now,
                AssignedTo = report.AssignedTo,
                Status = report.Status
            };

            context.DeletedReports.Add(deletedReport);
            context.Report.Remove(report);

            await context.SaveChangesAsync();
        }

        NavigationManager.NavigateTo("/reports", forceLoad: true);
    }

    private async Task ExportCsv()
    {
        using var context = DbFactory.CreateDbContext();

        var exportReports = await context.Report.ToListAsync();

        var csv = new StringBuilder();

        csv.AppendLine("Id,Title,DueDate,Type,Priority,AssignedTo,Status,Description");

        foreach (var report in exportReports)
        {
            csv.AppendLine(
                $"{report.Id}," +
                $"\"{report.Title}\"," +
                $"{report.DueDate}," +
                $"\"{report.Type}\"," +
                $"{report.Priority}," +
                $"\"{report.AssignedTo}\"," +
                $"\"{report.Status}\"," +
                $"\"{report.Description}\""
            );
        }

        var bytes = Encoding.UTF8.GetBytes(csv.ToString());
        var base64 = Convert.ToBase64String(bytes);

        await JS.InvokeVoidAsync(
            "downloadFile",
            "reports.csv",
            "text/csv",
            base64
        );
    }

    private IEnumerable<Report> FilteredReports =>
        string.IsNullOrWhiteSpace(searchText)
            ? reports
            : reports.Where(report =>
                (report.Title ?? "").ToLower().Contains(searchText.ToLower()) ||
                (report.Type ?? "").ToLower().Contains(searchText.ToLower()) ||
                (report.AssignedTo ?? "").ToLower().Contains(searchText.ToLower()) ||
                (report.Status ?? "").ToLower().Contains(searchText.ToLower()) ||
                (report.Description ?? "").ToLower().Contains(searchText.ToLower()));
}

<script>
    function downloadFile(filename, contentType, base64Data) {
        const link = document.createElement('a');

        link.download = filename;
        link.href = `data:${contentType};base64,${base64Data}`;

        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }
</script>