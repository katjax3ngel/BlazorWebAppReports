@page "/reports/create"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using BlazorWebAppReports.Models
@inject IDbContextFactory<BlazorWebAppReports.Data.ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h2>Report</h2>
<hr />

<div class="row">
    <div class="col-md-4">
        <EditForm Model="NewReport" OnValidSubmit="AddReport">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <div class="mb-3">
                <label for="title" class="form-label">Title:</label>
                <InputText id="title" @bind-Value="NewReport.Title" class="form-control" />
                <ValidationMessage For="() => NewReport.Title" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="duedate" class="form-label">Due Date:</label>
                <InputDate id="duedate" @bind-Value="NewReport.DueDate" class="form-control" />
                <ValidationMessage For="() => NewReport.DueDate" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="type" class="form-label">Type:</label>
                <InputSelect id="type" class="form-control" @bind-Value="NewReport.Type">
                    <option value="">-- Select Type --</option>
                    <option value="Bug">Bug</option>
                    <option value="Feature">Feature</option>
                    <option value="Nice to Have">Nice to Have</option>
                    <option value="Other">Other</option>
                </InputSelect>
                <ValidationMessage For="() => NewReport.Type" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="priority" class="form-label">Priority:</label>
                <InputNumber id="priority" @bind-Value="NewReport.Priority" class="form-control" />
                <ValidationMessage For="() => NewReport.Priority" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="assignedTo" class="form-label">Assigned To:</label>
                <InputSelect id="assignedTo" class="form-control" @bind-Value="NewReport.AssignedTo">
                    <option value="">-- Select Team Member --</option>
                    <option value="Christina Chamberlain">Christina Chamberlain</option>
                    <option value="Kyle Tuchon">Kyle Tuchon</option>
                    <option value="Braden Cantu">Braden Cantu</option>
                    <option value="Danielle McCartney">Danielle McCartney</option>
                    <option value="Benjamin Sherill">Benjamin Sherill</option>
                </InputSelect>
                <ValidationMessage For="() => NewReport.AssignedTo" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="status" class="form-label">Status:</label>
                <InputSelect id="status" class="form-control" @bind-Value="NewReport.Status">
                    <option value="">-- Select Status --</option>
                    <option value="Open">Open</option>
                    <option value="In Progress">In Progress</option>
                    <option value="Pending">Pending</option>
                    <option value="Resolved">Resolved</option>
                    <option value="Closed">Closed</option>
                </InputSelect>
                <ValidationMessage For="() => NewReport.Status" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="description" class="form-label">Description:</label>
                <InputTextArea id="description" @bind-Value="NewReport.Description" class="form-control" />
                <ValidationMessage For="() => NewReport.Description" class="text-danger" />
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
            <a href="/reports" class="btn btn-secondary ms-2">Cancel</a>
        </EditForm>
    </div>
</div>

<div class="mt-3">
    <a href="/reports">Back to List</a>
</div>

@code {
    private Report NewReport { get; set; } = new();

    private async Task AddReport()
    {
        using var context = DbFactory.CreateDbContext();

        context.Report.Add(NewReport);

        await context.SaveChangesAsync();

        NavigationManager.NavigateTo("/reports");
    }
}